# Copy this file to .env and fill in real values. NEVER commit .env.
# All vars are exposed to the browser (Vite VITE_ prefix). The anon key is
# safe to expose ONLY because Row-Level Security is enabled in the DB.

# Supabase project base URL — e.g. https://abcdefgh.supabase.co
# Use the BASE project URL, NOT the .../rest/v1/ endpoint.
VITE_SUPABASE_URL=

# Supabase anon/public key (Project Settings -> API -> Project API keys -> anon public).
# Do NOT use the service_role key here.
VITE_SUPABASE_ANON_KEY=

# Comma-separated list of valid moderator PINs. Any match grants access.
# Example: 1234,9999,go-team
VITE_MODERATOR_PINS=1234
